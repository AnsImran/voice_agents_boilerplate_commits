# Copy to .env and fill in. The real .env is gitignored.

# LiveKit project (account → project → agents). Swap these when moving to the
# dedicated "Parachute Technologies" project.
LIVEKIT_URL=wss://<your-project>.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# ConnectWise PSA REST API
CW_COMPANY_ID=
CW_PUBLIC_KEY=
CW_PRIVATE_KEY=
CW_SITE_DOMAIN=na.myconnectwise.net
CW_API_BASE=https://api-na.myconnectwise.net/v2025_1/apis/3.0
CW_CLIENT_ID=
